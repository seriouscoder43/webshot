{
    "version": 10,
    "configurePresets": [
        {
            "name": "configure-preset-clang",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_C_COMPILER_LAUNCHER": "ccache",
                "CMAKE_CXX_COMPILER_LAUNCHER": "ccache",
                "WEBSHOT_CLANG_FORMAT": "clang-format",
                "USERVER_PYTHON_PATH": "$env{USERVER_PYTHON_PATH}",
                "WEBSHOT_USE_MOLD": "ON",
                "WEBSHOT_ENABLE_LLVM_SYMBOLIZER": "ON",
                "WEBSHOT_ENABLE_SQL_COVERAGE": "OFF",
                "userver_DIR": "$env{USERVER_DIR}",
                "USERVER_FEATURE_TESTSUITE": "ON",
                "USERVER_TESTSUITE_USE_VENV": "OFF",
                "USERVER_SQL_USE_VENV": "OFF",
                "USERVER_CHAOTIC_USE_VENV": "OFF",
                "TESTSUITE_PYTHON_BINARY": "$env{USERVER_PYTHON_PATH}"
            },
            "generator": "Ninja",
            "warnings": {
                "dev": false
            }
        },
        {
            "name": "configure-preset-clang-san",
            "inherits": "configure-preset-clang",
            "binaryDir": "/tmp/build-${sourceDirName}-san",
            "cacheVariables": {
                "CMAKE_CXX_CLANG_TIDY": "",
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "USE_SANITIZERS": "ON",
                "BUILD_TESTING": "ON",
                "WEBSHOT_LLVM_SYMBOLIZER_BIN": "$env{WEBSHOT_LLVM_SYMBOLIZER_BIN}"
            }
        },
        {
            "name": "configure-preset-clang-tidy",
            "inherits": "configure-preset-clang-san",
            "binaryDir": "/tmp/build-${sourceDirName}-tidy",
            "cacheVariables": {
                "CMAKE_CXX_CLANG_TIDY": "clang-tidy"
            }
        },
        {
            "name": "configure-preset-clang-cov",
            "inherits": "configure-preset-clang",
            "binaryDir": "/tmp/build-${sourceDirName}-cov",
            "cacheVariables": {
                "CMAKE_CXX_CLANG_TIDY": "",
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "USE_SANITIZERS": "ON",
                "BUILD_TESTING": "ON",
                "WEBSHOT_ENABLE_COVERAGE": "ON",
                "WEBSHOT_LLVM_COV_BIN": "llvm-cov",
                "WEBSHOT_LLVM_PROFDATA_BIN": "llvm-profdata",
                "WEBSHOT_LLVM_SYMBOLIZER_BIN": "$env{WEBSHOT_LLVM_SYMBOLIZER_BIN}"
            }
        },
        {
            "name": "configure-preset-clang-release",
            "inherits": "configure-preset-clang",
            "binaryDir": "/tmp/build-${sourceDirName}-release",
            "cacheVariables": {
                "CMAKE_CXX_CLANG_TIDY": "",
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "USE_SANITIZERS": "OFF",
                "BUILD_TESTING": "OFF"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "build-preset-clang-san",
            "configurePreset": "configure-preset-clang-san"
        },
        {
            "name": "build-preset-clang-tidy",
            "configurePreset": "configure-preset-clang-tidy"
        },
        {
            "name": "build-preset-clang-cov",
            "configurePreset": "configure-preset-clang-cov"
        },
        {
            "name": "build-preset-clang-release",
            "configurePreset": "configure-preset-clang-release"
        }
    ],
   "testPresets": [
       {
           "name": "test-preset-clang",
           "configurePreset": "configure-preset-clang",
           "environment": {
               "PYTHONPYCACHEPREFIX": "/tmp/pycache-webshot"
           }
       }
   ]
}
